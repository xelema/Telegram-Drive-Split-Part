{
  "identifier": "mobile-only",
  "description": "Permissions required only on Android",
  "platforms": [
    "android"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$APPCACHE/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$APPCACHE/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    "dialog:default",
    "opener:default",
    "shell:allow-open"
  ]
}
