{
  "identifier": "default",
  "description": "Standard permissions for Telegram Drive",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "os:default",
    "shell:allow-open",
    "store:default",
    "updater:default",
    "process:allow-restart",
    "deep-link:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read",
    "fs:allow-write",
    "fs:scope-app-recursive"
  ]
}